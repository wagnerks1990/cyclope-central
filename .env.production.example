# Production template. Replace every placeholder before deployment.
CYCLOPE_ENVIRONMENT=production
CYCLOPE_DATABASE_URL=postgresql+psycopg://cyclope:REPLACE_WITH_DB_PASSWORD@postgres:5432/cyclope
CYCLOPE_REDIS_URL=redis://redis:6379/0
CYCLOPE_JWT_SECRET=REPLACE_WITH_32_PLUS_RANDOM_CHARACTERS
CYCLOPE_TOKEN_HASH_PEPPER=REPLACE_WITH_32_PLUS_RANDOM_CHARACTERS
CYCLOPE_CORS_ALLOWED_ORIGINS=https://central.example.com
CYCLOPE_LOG_LEVEL=INFO
CYCLOPE_SMTP_HOST=smtp.example.com
CYCLOPE_SMTP_PORT=587
CYCLOPE_SMTP_USERNAME=REPLACE_WITH_SMTP_USERNAME
CYCLOPE_SMTP_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
CYCLOPE_SMTP_FROM_EMAIL=cyclope-central@example.com
CYCLOPE_SMTP_USE_TLS=true
NEXT_PUBLIC_API_BASE_URL=https://central.example.com/api
NEXT_PUBLIC_DEFAULT_ORGANIZATION_ID=
POSTGRES_USER=cyclope
POSTGRES_PASSWORD=REPLACE_WITH_DB_PASSWORD
POSTGRES_DB=cyclope
