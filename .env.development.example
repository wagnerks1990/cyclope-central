# Development-only placeholders. Do not use in production.
CYCLOPE_ENVIRONMENT=development
CYCLOPE_DATABASE_URL=postgresql+psycopg://cyclope:change-me-db-password@postgres:5432/cyclope
CYCLOPE_REDIS_URL=redis://redis:6379/0
CYCLOPE_JWT_SECRET=replace-with-dev-secret-at-least-32-characters
CYCLOPE_TOKEN_HASH_PEPPER=replace-with-dev-token-pepper-32-chars
CYCLOPE_CORS_ALLOWED_ORIGINS=http://localhost:3000
CYCLOPE_LOG_LEVEL=INFO
CYCLOPE_SMTP_HOST=localhost
CYCLOPE_SMTP_PORT=1025
CYCLOPE_SMTP_USERNAME=
CYCLOPE_SMTP_PASSWORD=
CYCLOPE_SMTP_FROM_EMAIL=cyclope-central@example.local
CYCLOPE_SMTP_USE_TLS=false
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_DEFAULT_ORGANIZATION_ID=
POSTGRES_USER=cyclope
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=cyclope

# RustDesk OSS remote access provider
RUSTDESK_SERVER_HOST=localhost
RUSTDESK_RELAY_HOST=localhost
RUSTDESK_PUBLIC_KEY=
